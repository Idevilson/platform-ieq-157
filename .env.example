# ===========================================
# Firebase Client
# ===========================================
# JSON: {"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}
# Local .env: base64 encoded | Vercel: raw JSON
FIREBASE_CLIENT_CONFIG=

# ===========================================
# Firebase Admin
# ===========================================
# JSON: Service account JSON from Firebase Console
# Local .env: base64 encoded | Vercel: raw JSON
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# ===========================================
# Asaas Payment Gateway
# ===========================================
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=

# ===========================================
# Application
# ===========================================
APP_URL=http://localhost:3000

# ===========================================
# Daily Report Cron (WhatsApp via Evolution API)
# ===========================================
# Secret usado pelo Vercel Cron pra autenticar o GET no endpoint.
# Gere com: openssl rand -hex 32
CRON_SECRET=

# Evolution API self-hosted — em produção, URL pública HTTPS da VPS.
# Em dev local, pode apontar pra mesma URL pública ou rodar Evolution local em http://localhost:8080
EVOLUTION_BASE_URL=https://evolution.descoladao.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=descoladao-stats

# Destino do relatório (formato grupo: 1203...@g.us · DM: 5594...@s.whatsapp.net)
WHATSAPP_GROUP_ID=

# ID do evento no Firestore que vira fonte do relatório.
# Trocar quando o evento atual acabar.
REPORT_EVENT_ID=geracao-forte
